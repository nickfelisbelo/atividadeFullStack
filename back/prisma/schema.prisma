// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Turmas {
  id          Int         @id @default(autoincrement())
  serie       String
  materia     String
  professorId Int
  professor   Professores @relation(fields: [professorId], references: [id])
}

model Professores {
  id     Int      @id @default(autoincrement())
  nome   String
  email  String
  senha  String
  turmas Turmas[]
}
